---
// src/pages/index.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tusk - Computational Intelligence</title>
  <meta name="description" content="Tusk — a symbolic calculus engine powered by WebAssembly. Solve integrals step-by-step with full working shown." />
  <link rel="icon" type="image/svg+xml" href="/tusk/favicon.svg" />
  
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <style is:global>
    :root {
      --bg-color: #0a0a0f;
      --panel-bg: #14141f;
      --panel-bg-hover: #1a1a2a;
      --border: #252535;
      --border-accent: #3a3a55;
      --accent: #f96302;
      --accent-glow: rgba(249, 99, 2, 0.15);
      --accent-dim: #c44f00;
      --text: #e0e0e8;
      --text-dim: #7a7a90;
      --text-muted: #50506a;
      --step-line: #2a2a40;
      --step-badge: #f96302;
      --step-badge-text: #fff;
      --success: #34d399;
      --success-glow: rgba(52, 211, 153, 0.12);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text);
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100vh;
    }

    .tusk-app {
      width: 100%;
      max-width: 820px;
      padding: 3.5rem 1.25rem 4rem;
    }

    /* ── Header ── */
    .tusk-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .tusk-logo {
      width: 52px;
      height: 52px;
      margin-bottom: 0.75rem;
      filter: drop-shadow(0 0 12px rgba(249, 99, 2, 0.3));
    }
    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #fff 0%, #c8c8d8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .subtitle {
      color: var(--text-dim);
      font-size: 0.95rem;
      margin-top: 0.35rem;
      margin-bottom: 2rem;
      font-weight: 400;
    }

    /* ── Search Bar ── */
    .wa-search-bar {
      display: flex;
      width: 100%;
      background: var(--panel-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.03) inset;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .wa-search-bar:focus-within {
      border-color: var(--accent);
      box-shadow: 0 4px 24px rgba(0,0,0,0.4), 0 0 20px var(--accent-glow);
    }
    .wa-search-bar input {
      flex: 1;
      padding: 1.1rem 1.4rem;
      background: transparent;
      border: none;
      color: #fff;
      font-size: 1.1rem;
      outline: none;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 400;
    }
    .wa-search-bar input::placeholder {
      color: var(--text-muted);
    }
    .wa-search-bar button {
      background: var(--accent);
      color: white;
      border: none;
      padding: 0 2rem;
      cursor: pointer;
      font-size: 1.4rem;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      transition: background 0.2s, transform 0.1s;
    }
    .wa-search-bar button:hover {
      background: var(--accent-dim);
    }
    .wa-search-bar button:active {
      transform: scale(0.97);
    }

    /* ── Pods (Input / Result) ── */
    .wa-pod {
      background: var(--panel-bg);
      border: 1px solid var(--border);
      margin-bottom: 1rem;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,0.25);
    }
    .wa-pod-title {
      background: rgba(255,255,255,0.02);
      padding: 0.65rem 1.4rem;
      font-size: 0.72rem;
      color: var(--text-dim);
      border-bottom: 1px solid var(--border);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 600;
    }
    .wa-pod-content {
      padding: 2rem 1.4rem;
      overflow-x: auto;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 1.4rem;
    }

    /* ── Steps Timeline ── */
    .steps-container {
      margin-top: 0.5rem;
      margin-bottom: 1.5rem;
    }
    .steps-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.65rem 1.4rem;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      border-bottom: none;
      border-radius: 12px 12px 0 0;
      font-size: 0.72rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 600;
    }
    .steps-header-icon {
      font-size: 0.85rem;
    }
    .steps-list {
      background: var(--panel-bg);
      border: 1px solid var(--border);
      border-radius: 0 0 12px 12px;
      padding: 1.5rem 1.4rem 1rem;
      position: relative;
    }

    .step-item {
      display: flex;
      gap: 1rem;
      position: relative;
      padding-bottom: 1.5rem;
      opacity: 0;
      transform: translateY(8px);
      animation: stepReveal 0.35s ease-out forwards;
    }
    .step-item:last-child {
      padding-bottom: 0.25rem;
    }

    /* Vertical connecting line */
    .step-item::before {
      content: '';
      position: absolute;
      left: 15px;
      top: 32px;
      bottom: 0;
      width: 2px;
      background: var(--step-line);
    }
    .step-item:last-child::before {
      display: none;
    }

    .step-badge {
      flex-shrink: 0;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--step-badge);
      color: var(--step-badge-text);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 700;
      z-index: 1;
      box-shadow: 0 0 8px var(--accent-glow);
    }
    .step-item.step-final .step-badge {
      background: var(--success);
      box-shadow: 0 0 10px var(--success-glow);
    }

    .step-body {
      flex: 1;
      min-width: 0;
    }
    .step-rule {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 0.25rem;
    }
    .step-item.step-final .step-rule {
      color: var(--success);
    }
    .step-detail {
      font-size: 0.82rem;
      color: var(--text-dim);
      line-height: 1.5;
      margin-bottom: 0.6rem;
      font-style: italic;
    }
    .step-transformation {
      padding: 0.85rem 1rem;
      background: rgba(255,255,255,0.025);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow-x: auto;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      font-size: 1.15rem;
      transition: background 0.2s;
    }
    .step-transformation:hover {
      background: rgba(255,255,255,0.04);
    }
    .step-item.step-final .step-transformation {
      border-color: rgba(52, 211, 153, 0.25);
      background: rgba(52, 211, 153, 0.04);
    }
    .step-arrow {
      color: var(--accent);
      font-size: 1rem;
      flex-shrink: 0;
      opacity: 0.7;
    }
    .step-latex-before {
      opacity: 0.5;
    }

    @keyframes stepReveal {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ── Loading spinner ── */
    .wa-loading {
      display: none;
      justify-content: center;
      padding: 2rem;
    }
    .wa-loading.active {
      display: flex;
    }
    .spinner {
      width: 24px;
      height: 24px;
      border: 3px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      .tusk-app { padding: 2rem 0.75rem; }
      h1 { font-size: 1.75rem; }
      .wa-search-bar input { font-size: 0.95rem; padding: 0.9rem 1rem; }
      .wa-search-bar button { padding: 0 1.4rem; font-size: 1.2rem; }
      .wa-pod-content { font-size: 1.1rem; padding: 1.4rem 1rem; }
      .step-latex { font-size: 0.95rem; }
    }
  </style>
</head>
<body>
  <div class="tusk-app">
    <header class="tusk-header">
      <img src="/tusk/tusk_logo.svg" alt="Tusk Logo" class="tusk-logo" />
      <h1>Tusk</h1>
      <p class="subtitle">Computational Intelligence</p>
      
      <div class="wa-search-bar">
        <input type="text" id="waInput" placeholder="int(x^2 + sin(x))" autocomplete="off" spellcheck="false" />
        <button id="waSubmit">=</button>
      </div>
    </header>

    <main class="wa-content">
      <div class="wa-pod" id="pod-input" style="display: none;">
        <h2 class="wa-pod-title">Input Interpretation</h2>
        <div class="wa-pod-content" id="wa-input-render"></div>
      </div>

      <div class="steps-container" id="steps-container" style="display: none;">
        <div class="steps-header">
          <span class="steps-header-icon">⧫</span>
          Solution Steps
        </div>
        <div class="steps-list" id="steps-list"></div>
      </div>

      <div class="wa-pod" id="pod-result" style="display: none;">
        <h2 class="wa-pod-title">Result</h2>
        <div class="wa-pod-content" id="wa-result-render"></div>
      </div>
    </main>
  </div>

  <script type="module">
    import init, { solve_latex, parse_to_latex, solve_steps_json } from '/tusk/pkg/tusk.js';

    async function loadEngine() {
      try {
        await init();
      } catch (e) {
        console.error("Wasm Init Failed:", e);
      }
    }
    
    loadEngine();

    function renderSteps(stepsJson) {
      const container = document.getElementById('steps-container');
      const list = document.getElementById('steps-list');
      
      let steps;
      try {
        steps = JSON.parse(stepsJson);
      } catch (e) {
        console.error("Failed to parse steps JSON:", e);
        container.style.display = 'none';
        return;
      }

      if (!steps || steps.length <= 1) {
        // Only a final result, no intermediate steps worth showing
        container.style.display = 'none';
        return;
      }

      list.innerHTML = '';
      container.style.display = 'block';

      steps.forEach((step, idx) => {
        const isFinal = step.description === 'Final Result';
        
        const item = document.createElement('div');
        item.className = 'step-item' + (isFinal ? ' step-final' : '');
        item.style.animationDelay = `${idx * 0.08}s`;

        const badge = document.createElement('div');
        badge.className = 'step-badge';
        badge.textContent = isFinal ? '✓' : step.step;

        const body = document.createElement('div');
        body.className = 'step-body';

        const rule = document.createElement('div');
        rule.className = 'step-rule';
        rule.textContent = step.description;

        const detail = document.createElement('div');
        detail.className = 'step-detail';
        try {
          // Render inline KaTeX for any text wrapped in $ $
          detail.innerHTML = step.change_detail.replace(/\$([^\$]+)\$/g, (match, tex) => {
            return katex.renderToString(tex, { throwOnError: false, displayMode: false });
          });
        } catch (e) {
          detail.textContent = step.change_detail;
        }

        const transformation = document.createElement('div');
        transformation.className = 'step-transformation';

        body.appendChild(rule);
        body.appendChild(detail);
        body.appendChild(transformation);
        item.appendChild(badge);
        item.appendChild(body);
        list.appendChild(item);

        // Render before → after LaTeX
        try {
          if (!isFinal && step.before_latex && step.before_latex !== step.after_latex) {
            const beforeEl = document.createElement('span');
            beforeEl.className = 'step-latex-before';
            katex.render(step.before_latex, beforeEl, { throwOnError: false, displayMode: false });
            transformation.appendChild(beforeEl);

            const arrow = document.createElement('span');
            arrow.className = 'step-arrow';
            arrow.textContent = '→';
            transformation.appendChild(arrow);
          }

          const afterEl = document.createElement('span');
          katex.render(step.after_latex, afterEl, { throwOnError: false, displayMode: false });
          transformation.appendChild(afterEl);
        } catch (e) {
          transformation.textContent = step.after_latex;
        }
      });
    }

    window.runEnginePipeline = function() {
      const input = document.getElementById('waInput');
      const renderInput = document.getElementById('wa-input-render');
      const renderResult = document.getElementById('wa-result-render');
      
      if (!input || !input.value.trim()) return;
      const rawInput = input.value.trim();
      
      try {
        const inputLatex = parse_to_latex(rawInput);
        const resultLatex = solve_latex(rawInput);
        const stepsJson = solve_steps_json(rawInput);

        document.getElementById('pod-input').style.display = 'block';
        document.getElementById('pod-result').style.display = 'block';
        
        katex.render(inputLatex, renderInput, {
            throwOnError: false,
            displayMode: true
        });
        
        katex.render(resultLatex, renderResult, {
            throwOnError: false,
            displayMode: true
        });

        renderSteps(stepsJson);
      } catch (err) {
        console.error("Execution error:", err);
      }
    }

    document.getElementById('waSubmit')?.addEventListener('click', window.runEnginePipeline);
    document.getElementById('waInput')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') window.runEnginePipeline();
    });
  </script>
</body>
</html>

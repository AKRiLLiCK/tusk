---
const { docFiles, activeSlug } = Astro.props;

const order = ['README.md', 'grammar.md', 'language.md'];
const sortedDocs = docFiles
  .filter((doc: any) => !doc.file.endsWith('SUMMARY.md'))
  .sort((a: any, b: any) => {
    const aFile = a.file.split('/').pop();
    const bFile = b.file.split('/').pop();
    
    const aIndex = order.indexOf(aFile);
    const bIndex = order.indexOf(bFile);
    return (aIndex === -1 ? 999 : aIndex) - (bIndex === -1 ? 999 : bIndex);
  });

const getTitle = (filename: string) => {
  if (filename === 'README.md') return 'Introduction';
  if (filename === 'grammar.md') return 'Syntax Grammar';
  if (filename === 'language.md') return 'Language Guide';

  return filename.replace('.md', '');
};

const getUrl = (filename: string) => {
  if (filename === 'README.md') return '/tusk/docs';
  return `/tusk/docs/${filename.replace('.md', '')}`;
};

const searchIndex = sortedDocs.map((doc: any) => {
  const filename = doc.file.split('/').pop();
  return {
    title: getTitle(filename),
    url: getUrl(filename),
    headings: doc.getHeadings()
  };
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tusk - Documentation</title>
  <link rel="icon" type="image/svg+xml" href="/tusk/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      --bg-color: #0a0a0f;
      --panel-bg: #14141f;
      --border: #252535;
      --accent: #f96302;
      --text: #e0e0e8;
      --text-dim: #7a7a90;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background-color: var(--bg-color);
      color: var(--text);
      font-family: 'Inter', system-ui, sans-serif;
      min-height: 100vh;
      line-height: 1.6;
      display: flex;
      flex-direction: column;
    }
    .top-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      padding: 1rem 1.25rem;
      background: var(--panel-bg);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-buttons {
      display: flex;
      gap: 0.75rem;
    }
    .nav-btn {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 0.6rem 1.2rem;
      color: var(--text);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.9rem;
      transition: all 0.2s ease;
    }
    .nav-btn:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: #3a3a55;
      color: #fff;
    }
    .nav-branding {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .nav-logo {
      width: 28px;
      height: 28px;
      filter: drop-shadow(0 0 8px rgba(249, 99, 2, 0.4));
    }
    .nav-title {
      font-size: 1.2rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.02em;
    }

    .docs-layout {
      display: grid;
      grid-template-columns: 280px 1fr;
      flex: 1;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    .sidebar {
      border-right: 1px solid var(--border);
      padding: 2rem 1.5rem;
      background: var(--bg-color);
      position: sticky;
      top: 70px;
      height: calc(100vh - 70px);
      overflow-y: auto;
    }

    .search-box {
      width: 100%;
      padding: 0.8rem 1rem;
      background: var(--panel-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: #fff;
      margin-bottom: 2rem;
      outline: none;
      font-family: inherit;
      transition: border-color 0.2s;
    }
    .search-box:focus {
      border-color: var(--accent);
    }

    .sidebar-nav ul {
      list-style: none;
      padding-left: 0;
    }
    .sidebar-nav li {
      margin-bottom: 0.5rem;
    }
    .sidebar-nav a {
      color: var(--text-dim);
      text-decoration: none;
      font-size: 0.95rem;
      transition: color 0.2s;
      display: block;
      padding: 0.3rem 0;
    }
    .sidebar-nav a:hover {
      color: #fff;
    }
    .sidebar-nav a.active {
      color: var(--accent);
      font-weight: 600;
    }

    .sidebar-headings {
      margin-top: 0.5rem;
      padding-left: 1rem;
      border-left: 1px solid var(--border);
      display: none;
    }
    .sidebar-headings.show {
      display: block;
    }
    .sidebar-headings a {
      font-size: 0.85rem;
      padding: 0.2rem 0;
    }

    .main-content {
      padding: 3.5rem 3rem 5rem;
      max-width: 820px;
      width: 100%;
    }

    .markdown-content h1, .markdown-content h2, .markdown-content h3 { color: #fff; margin-bottom: 1rem; margin-top: 2.5rem; }
    .markdown-content h1 { font-size: 2.5rem; font-weight: 700; background: linear-gradient(135deg, #fff 0%, #c8c8d8 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-top: 0; margin-bottom: 2rem; }
    .markdown-content h2 { font-size: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
    .markdown-content h3 { font-size: 1.1rem; color: var(--accent); }
    .markdown-content p { margin-bottom: 1.25rem; color: var(--text-dim); }
    .markdown-content ul { margin-bottom: 1.25rem; padding-left: 1.5rem; color: var(--text-dim); }
    .markdown-content li { margin-bottom: 0.5rem; }
    .markdown-content code { font-family: 'JetBrains Mono', monospace; background: var(--panel-bg); padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.9em; border: 1px solid var(--border); }
    .markdown-content pre { background: var(--panel-bg); padding: 1.25rem; border-radius: 8px; border: 1px solid var(--border); overflow-x: auto; margin-bottom: 1.5rem; }
    .markdown-content pre code { background: none; border: none; padding: 0; font-size: 0.9em; }
    .markdown-content a { color: var(--accent); text-decoration: none; }
    .markdown-content a:hover { text-decoration: underline; }
    .markdown-content table { border-collapse: collapse; width: 100%; margin-bottom: 1.5rem; }
    .markdown-content th, .markdown-content td { padding: 0.75rem 1rem; border: 1px solid var(--border); text-align: left; }
    .markdown-content th { background: rgba(255, 255, 255, 0.05); color: #fff; font-weight: 600; }

    @media (max-width: 768px) {
      .docs-layout {
        grid-template-columns: 1fr;
      }
      .sidebar {
        height: auto;
        position: static;
        border-right: none;
        border-bottom: 1px solid var(--border);
        padding: 1.5rem;
      }
      .main-content {
        padding: 2rem 1.5rem;
      }
    }
  </style>
</head>
<body>
  <nav class="top-nav">
    <div class="nav-branding">
      <img src="/tusk/tusk_logo.svg" alt="Tusk Logo" class="nav-logo" />
      <span class="nav-title">Tusk</span>
    </div>
    <div class="nav-buttons">
      <a href="/tusk" class="nav-btn">Engine</a>
      <a href="/tusk/docs" class="nav-btn">Documentation</a>
    </div>
  </nav>
  
  <div class="docs-layout">
    <aside class="sidebar">
      <input type="text" class="search-box" id="docs-search" placeholder="Search documentation..." autocomplete="off" />
      
      <nav class="sidebar-nav" id="sidebar-nav">
        <ul>
          {sortedDocs.map((doc: any) => {
            const filename = doc.file.split('/').pop();
            const title = getTitle(filename);
            const url = getUrl(filename);
            const currentSlug = filename === 'README.md' ? undefined : filename.replace('.md', '');
            const isActive = activeSlug === currentSlug;
            return (
              <li class="nav-item">
                <a href={url} class={isActive ? "active" : ""}>{title}</a>
                <div class={`sidebar-headings ${isActive ? 'show' : ''}`}>
                  {doc.getHeadings().filter((h: any) => h.depth > 1).map((h: any) => (
                    <a href={`${url}#${h.slug}`}>{h.text}</a>
                  ))}
                </div>
              </li>
            );
          })}
        </ul>
      </nav>
    </aside>

    <main class="main-content markdown-content">
      <slot />
    </main>
  </div>

  <script define:vars={{ searchIndex }}>
    const searchInput = document.getElementById('docs-search');
    const sidebarNav = document.getElementById('sidebar-nav');
    
    // Store original HTML to restore when search is empty
    const originalNavHtml = sidebarNav.innerHTML;

    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      
      if (!query) {
        sidebarNav.innerHTML = originalNavHtml;
        return;
      }

      let resultsHtml = '<ul>';
      
      searchIndex.forEach(doc => {
        let hasDocMatch = doc.title.toLowerCase().includes(query);
        let matchingHeadings = doc.headings.filter(h => h.depth > 1 && h.text.toLowerCase().includes(query));
        
        if (hasDocMatch || matchingHeadings.length > 0) {
          resultsHtml += `<li class="nav-item" style="margin-bottom: 1rem;">`;
          resultsHtml += `<a href="${doc.url}" style="color: #fff; font-weight: 600;">${doc.title}</a>`;
          
          if (matchingHeadings.length > 0) {
            resultsHtml += `<div class="sidebar-headings show">`;
            matchingHeadings.forEach(h => {
              resultsHtml += `<a href="${doc.url}#${h.slug}">${h.text}</a>`;
            });
            resultsHtml += `</div>`;
          }
          resultsHtml += `</li>`;
        }
      });
      
      resultsHtml += '</ul>';
      
      if (resultsHtml === '<ul></ul>') {
        sidebarNav.innerHTML = '<p style="color: var(--text-dim); font-size: 0.9rem;">No results found.</p>';
      } else {
        sidebarNav.innerHTML = resultsHtml;
      }
    });
  </script>
</body>
</html>
